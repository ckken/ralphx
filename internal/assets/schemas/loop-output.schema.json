{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "mode",
    "exit_signal",
    "files_modified",
    "tests_passed",
    "blockers",
    "summary"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["in_progress", "blocked", "complete"]
    },
    "mode": {
      "type": "string",
      "enum": ["execute_next_step", "produce_plan", "blocked", "complete"]
    },
    "exit_signal": {
      "type": "boolean"
    },
    "files_modified": {
      "type": "integer",
      "minimum": 0
    },
    "tests_passed": {
      "type": "boolean"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "next_step": {
      "type": "string"
    },
    "checklist_update": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "in_progress" },
          "mode": { "const": "execute_next_step" }
        }
      },
      "then": {
        "properties": {
          "files_modified": { "type": "integer", "minimum": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "in_progress" },
          "mode": { "const": "produce_plan" }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": ["next_step"],
            "properties": {
              "next_step": { "type": "string", "minLength": 1 }
            }
          },
          {
            "required": ["checklist_update"],
            "properties": {
              "checklist_update": { "type": "array", "minItems": 1 }
            }
          }
        ]
      }
    }
  ]
}
